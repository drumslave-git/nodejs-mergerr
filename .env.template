# nodejs-mergerr environment configuration template.
# Copy this file to `.env` for local development (`npm run docker:dev:up` /
# `npm start`) and to `stack.env` for production (`npm run docker:up`).
# Do NOT commit your real `.env` — it is gitignored.

# --- qBittorrent connection -------------------------------------------------

# Hostname or full base URL of your qBittorrent Web UI.
# Accepts either "qb.example.com" or "https://qb.example.com".
QBIT_HOST=localhost

# Web UI port. Use 443 when QBIT_HOST starts with https://.
QBIT_PORT=8080

# qBittorrent Web UI credentials. Leave both blank if auth is disabled
# (e.g. "Bypass authentication for clients on localhost" is enabled).
QBIT_USER=
QBIT_PASSWORD=

# --- qBittorrent client tuning (optional) -----------------------------------

# Per-request timeout in milliseconds (1000–120000). Default: 10000.
# QBIT_REQUEST_TIMEOUT_MS=10000

# Max attempts per request, including the first one (1–10). Transient network
# errors (ECONNRESET, ETIMEDOUT, EAI_AGAIN, ...) are retried with exponential
# backoff. HTTP 4xx/5xx responses are NOT retried. Default: 3.
# QBIT_MAX_RETRIES=3

# Base backoff in milliseconds between retries; doubles each attempt
# (e.g. 500 -> 1000 -> 2000). Default: 500.
# QBIT_RETRY_BACKOFF_MS=500

# --- Server ---------------------------------------------------------------

# Port the Node server listens on inside the container. Default: 3000.
# Change only if you also update the compose port mappings.
# PORT=3000

# --- Docker compose ---------------------------------------------------------

# Host port to publish the Web UI on.
# - compose.yml      maps WEB_UI_PORT -> container :3000 (Node server)
# - compose.dev.yml  maps WEB_UI_PORT -> container :5555 (Vite dev server,
#                    which proxies /api and /events to the Node server)
WEB_UI_PORT=5555

# Container-side path that the torrents directory is mounted at. This MUST
# match the absolute paths qBittorrent reports for completed torrents,
# because the app reads those paths verbatim from the qBittorrent API.
TORRENTS_DIR=/downloads

# Host-side path that gets bind-mounted into the container at TORRENTS_DIR.
# Use an absolute path in production; a relative path like ./data works for
# local testing.
TORRENTS_DIR_HOST=./data
